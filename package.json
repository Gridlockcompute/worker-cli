{
  "name": "@gridlock-compute/native-worker",
  "version": "0.1.1",
  "description": "Native CLI worker for the Gridlock inference network. Connects over WebSocket and runs jobs via Ollama or vLLM.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gridlock-native-worker": "bin/gridlock-native-worker.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gridlockcompute/native-worker.git"
  },
  "homepage": "https://grid-lock.tech",
  "bugs": {
    "url": "https://github.com/Gridlockcompute/native-worker/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "gridlock",
    "gridlock-compute",
    "inference",
    "gpu",
    "ollama",
    "vllm",
    "worker",
    "evm",
    "robinhood"
  ],
  "dependencies": {
    "commander": "^12.1.0",
    "viem": "^2.23.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ]
}
